{
  "name": "homeassistant_dashboard_studio",
  "private": true,
  "version": "0.3.4",
  "type": "module",
  "description": "Home Assistant Dashboard Studio - pro-code Home Assistant dashboard as a custom panel, installable via HACS.",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build && node scripts/copy-dashboard.mjs",
    "check:default": "node scripts/check-default-project.mjs",
    "check:dashboard": "node scripts/validate-dashboard.mjs",
    "gen:types": "node scripts/gen-entity-types.mjs",
    "sync": "node scripts/sync.mjs",
    "sync:pull": "node scripts/sync.mjs pull",
    "sync:push": "node scripts/sync.mjs push",
    "sync:watch": "node scripts/sync.mjs watch"
  },
  "dependencies": {
    "@codemirror/lang-javascript": "^6.2.2",
    "@tanstack/react-virtual": "^3.14.3",
    "@uiw/react-codemirror": "^4.23.6",
    "home-assistant-js-websocket": "^9.4.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sucrase": "^3.35.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.6.3",
    "vite": "^6.0.3",
    "ws": "^8.18.0"
  }
}
