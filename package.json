{
  "name": "homeassistant_dashboard_studio",
  "private": true,
  "version": "0.0.11",
  "type": "module",
  "description": "Home Assistant Dashboard Studio - pro-code Home Assistant dashboard as a custom panel, installable via HACS.",
  "scripts": {
    "dev": "vite",
    "dev:default": "node scripts/dev-default.mjs",
    "prebuild": "node scripts/gen-eject-sources.mjs && node scripts/embed-default-project.mjs && node scripts/gen-sdk-reference.mjs",
    "build": "tsc --noEmit && tsc --noEmit -p default-dashboard && vite build && node scripts/copy-dashboard.mjs",
    "embed:default": "node scripts/embed-default-project.mjs",
    "check:default": "node scripts/check-default-project.mjs && tsc --noEmit -p default-dashboard",
    "check:dashboard": "node scripts/validate-dashboard.mjs",
    "gen:types": "node scripts/gen-entity-types.mjs",
    "gen:sdk-reference": "node scripts/gen-sdk-reference.mjs",
    "gen:eject-sources": "node scripts/gen-eject-sources.mjs",
    "eject:imports": "node scripts/eject-imports.mjs",
    "eject:dashboard": "node scripts/eject-dashboard.mjs",
    "eject:dashboard:list": "node scripts/eject-dashboard.mjs --list",
    "eject:dashboard:dry": "node scripts/eject-dashboard.mjs --dry",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "gen:all": "node scripts/gen-all.mjs",
    "sync": "node scripts/sync.mjs",
    "sync:pull": "node scripts/sync.mjs pull",
    "sync:push": "node scripts/sync.mjs push",
    "sync:watch": "node scripts/sync.mjs watch",
    "release:notes": "node scripts/release-notes.mjs"
  },
  "dependencies": {
    "@codemirror/lang-javascript": "^6.2.2",
    "@tanstack/react-virtual": "^3.14.3",
    "@uiw/react-codemirror": "^4.23.6",
    "home-assistant-js-websocket": "^9.4.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sucrase": "^3.35.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^10.5.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.62.0",
    "vite": "^6.0.3",
    "vitest": "^4.1.9",
    "ws": "^8.18.0"
  }
}
